Vagrant.configure("2") do |config|

  config.vm.box = "bento/ubuntu-22.04"

  config.vm.define "lab" do |vm|

    vm.vm.hostname = "lab"

    vm.vm.network "private_network",
      ip: "192.168.65.10"

    vm.vm.network "forwarded_port",
      guest: 22,
      host: 2222,
      id: "ssh",
      auto_correct: true

    vm.vm.provider "virtualbox" do |vb|

      vb.memory = 2048
      vb.cpus = 2

    end

    vm.vm.provision "shell",
      path: "scripts/lab.sh"

  end

  config.vm.define "storage" do |vm|

    vm.vm.hostname = "storage"

    vm.vm.network "private_network",
      ip: "192.168.65.20"

    vm.vm.provider "virtualbox" do |vb|

      vb.memory = 1024
      vb.cpus = 1

    end

    vm.vm.provision "shell",
      path: "scripts/storage.sh"

  end

end
